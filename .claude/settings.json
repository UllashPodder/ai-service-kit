      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "MultiEdit(**)",
      "Glob(**)",
      "Grep(**)",
      "LS(**)",
      "Bash(swift build)",
      "Bash(swift test)",
      "Bash(swift test *)",
      "Bash(swift build *)",
      "Bash(swift package resolve)",
      "Bash(swift package update)",
      "Bash(swift-format *)",
      "Bash(xcrun swift-format *)",
